FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     simpleFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         3000;

deltaT          1;

writeControl    timeStep;

writeInterval   1000;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;


functions
{
	wallShearStress
	{
		type	wallShearStress;
		libs            ("libfieldFunctionObjects.so");
		writeControl	writeTime;
		writeInterval   1;
		patches		(WALL);
	}

	viscousDissipationPhi
	{
	    type            coded;
		name            viscousDissipationPhi;
	    libs            ("libutilityFunctionObjects.so");
	    writeControl    writeTime;
	    writeInterval   1;

	    codeExecute
	    #{
	        const Foam::fvMesh& mesh = refCast<const Foam::fvMesh>(obr_);

	        // velocity
	        const Foam::volVectorField& U =
	            mesh.lookupObject<Foam::volVectorField>("U");

	        // transportProperties
	        const Foam::IOdictionary transportProperties
	        (
	            Foam::IOobject
	            (
	                "transportProperties",
	                mesh.time().constant(),
	                mesh,
	                Foam::IOobject::MUST_READ,
	                Foam::IOobject::NO_WRITE
	            )
	        );

	        // nu and rho
	        const Foam::dimensionedScalar nu
	        (
	            "nu",
	            Foam::dimViscosity,
	            transportProperties.lookup("nu")
	        );

	        const Foam::dimensionedScalar rho
	        (
	            "rho",
	            Foam::dimDensity,
	            transportProperties.lookup("rho")
	        );

	        // dynamic viscosity mu = rho * nu
	        const Foam::dimensionedScalar mu = rho * nu;

	        // strain-rate tensor
	        Foam::volSymmTensorField D
	        (
	            "D",
	            Foam::symm(Foam::fvc::grad(U))
	        );

	        // Phi = 2 * mu * (D:D)
	        Foam::volScalarField dissipationFunctionPhi
	        (
	            Foam::IOobject
	            (
	                "dissipationFunctionPhi",
	                mesh.time().timeName(),
	                mesh,
	                Foam::IOobject::NO_READ,
	                Foam::IOobject::AUTO_WRITE
	            ),
	            2.0 * mu * Foam::magSqr(D)
	        );

	        dissipationFunctionPhi.write();
	    #};
	}


